# Wymuszaj LF dla wszystkich plików tekstowych
* text=auto eol=lf

# Jawnie tekstowe
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.svg   text eol=lf

# Binarne – bez konwersji
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.woff  binary
*.woff2 binary
